{
  "routes": [
    {
      "src": "/index\\.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" },
      "continue": true
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "citypulsesf.com" }],
      "dest": "/citypulse-launch.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "www.citypulsesf.com" }],
      "dest": "/citypulse-launch.html"
    },
    { "handle": "filesystem" },
    {
      "src": "/((?!api/).+)",
      "dest": "/index.html"
    }
  ]
}
